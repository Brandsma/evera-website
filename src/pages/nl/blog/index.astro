---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import PostRows from '../../../components/PostRows.astro';
import Footer from '../../../components/sections/Footer.astro';
import { COPY } from '../../../i18n/copy';
import { SUBSTACK_URL } from '../../../config';
import { getPosts } from '../../../lib/substack';

const t = COPY.nl;
const posts = await getPosts();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  lang="nl"
  title={t.blog.title}
  description={t.blog.desc}
>
  <Nav t={t} enHref={`${base}blog/`} nlHref={`${base}nl/blog/`} />
  <main>
    <div class="blog-page">
      <div class="shell">
        <div class="blog-head">
          <a class="blog-back" href={`${base}nl/`}>← {t.blog.back}</a>
          <span class="eyebrow">{t.blog.eyebrow}</span>
          <h1 class="blog-title">
            {t.blog.headLead}<span class="it">{t.blog.headEm}</span>
          </h1>
          <p class="blog-desc">{t.blog.desc}</p>
        </div>
        {posts.length > 0 ? (
          <PostRows t={t} posts={posts} />
        ) : (
          <p class="posts-empty">{t.portfolio.empty}</p>
        )}
        <a class="follow-substack" href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer">
          {t.blog.follow} <span class="arrow">→</span>
        </a>
      </div>
    </div>
    <Footer t={t} />
  </main>
</BaseLayout>
