---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/sections/Footer.astro";
import { COPY } from "../../i18n/copy";
import { getPosts, type Post } from "../../lib/substack";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: Post;
}
const { post } = Astro.props;

const t = COPY.en;
const base = import.meta.env.BASE_URL;
const blogHref = `${base}blog/`;
---

<BaseLayout
  lang="en"
  title={`${post.title} · Evera`}
  description={post.description}
>
  <Nav t={t} enHref={blogHref} nlHref={`${base}nl/blog/`} />
  <main>
    <article class="post">
      <div class="post-shell">
        <a class="post-back" href={blogHref}>← {t.post.back}</a>
        <div class="post-head-meta">
          <span>{post.dates.en}</span>
          <span class="dot">·</span>
          <span>{post.readingTime} {t.readingLabel}</span>
        </div>
        <h1 class="post-h1">{post.title}</h1>
        {
          post.cover && (
            <div class="post-cover">
              <img src={post.cover} alt="" />
            </div>
          )
        }
        {
          post.audio && (
            <div class="post-audio">
              <audio controls preload="metadata" src={post.audio}>
                <a href={post.audio}>Download audio</a>
              </audio>
            </div>
          )
        }
        <div class="post-body" set:html={post.html} />
        <div class="post-footer">
          <a
            class="follow-substack"
            href={post.link}
            target="_blank"
            rel="noopener noreferrer"
          >
            {t.post.follow}
            <span class="arrow">→</span>
          </a>
          <a class="post-back-bottom" href={blogHref}>← {t.post.back}</a>
        </div>
      </div>
    </article>
    <Footer t={t} />
  </main>
</BaseLayout>
