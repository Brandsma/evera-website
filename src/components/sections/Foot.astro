---
import type { Copy } from '../../i18n/copy';
import NewsletterForm from '../NewsletterForm';
interface Props { t: Copy }
const { t } = Astro.props;
---

<section class="section" id="visit">
  <div class="shell">
    <div class="foot-grid">
      <!-- Newsletter: React island for form state -->
      <NewsletterForm client:visible t={t} />

      <!-- Contact: static -->
      <div>
        <span class="eyebrow">{t.foot.contact.eyebrow}</span>
        <h3 style="margin-top: 16px">
          {t.foot.contact.headLead} <span class="it">{t.foot.contact.headEm}</span>
        </h3>
        <p>{t.foot.contact.desc}</p>
        <div class="contact-block">
          {t.foot.contact.rows.map(([label, value, href]) => (
            <div class="row">
              <span class="k">{label}</span>
              {href ? (
                <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {value}
                </a>
              ) : (
                <span>{value}</span>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
