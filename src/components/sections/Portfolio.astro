---
import type { Copy } from '../../i18n/copy';
import type { Post } from '../../lib/substack';
import PostRows from '../PostRows.astro';
import { SOCIAL_LINKS } from '../../config';

interface Props {
  t: Copy;
  posts: Post[];
}

const { t, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
const blogHref = t.lang === 'en' ? `${base}blog/` : `${base}nl/blog/`;
---

<section class="section portfolio" id="portfolio">
  <div class="shell">
    <div class="portfolio-head">
      <h2>
        {t.portfolio.headLead} <span class="it">{t.portfolio.headEm}</span>
      </h2>
      <div class="right">
        <span class="eyebrow">{t.portfolio.eyebrow}</span>
        <p>{t.portfolio.desc}</p>
      </div>
    </div>
    {posts.length > 0 ? (
      <PostRows t={t} posts={posts} />
    ) : (
      <p class="posts-empty">{t.portfolio.empty}</p>
    )}
    <div class="portfolio-foot">
      <a class="read-all" href={blogHref}>
        {t.portfolio.readAll} <span class="arrow">→</span>
      </a>
      <div class="social-row">
        {SOCIAL_LINKS.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>
        ))}
      </div>
    </div>
  </div>
</section>
