---
import type { Copy } from '../../i18n/copy';
import { asset } from '../../lib/asset';
interface Props { t: Copy }
const { t } = Astro.props;
---

<section class="section archive" id="archive">
  <div class="shell">
    <div class="archive-head">
      <h2>{t.archive.headLead} <span class="it">{t.archive.headEm}</span></h2>
      <div class="right">
        <span class="eyebrow">{t.archive.eyebrow}</span>
        <p style="margin-top: 12px">{t.archive.desc}</p>
      </div>
    </div>
    <div class="gallery">
      {t.archive.tiles.map((tile, i) => (
        <div class={`tile t${i + 1}${tile.video ? ' video' : ''}`}>
          <img
            src={asset(`images/${tile.img}`)}
            alt={tile.ttl}
            loading="lazy"
          />
          {tile.video && <div class="play" aria-label="Play video">▶</div>}
          <div class="info">
            <span class="ttl">{tile.ttl}</span>
            <span class="tag">{tile.tag}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
