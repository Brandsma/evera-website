---
import type { Copy } from '../../i18n/copy';
interface Props { t: Copy }
const { t } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="section" id="workshops">
  <div class="shell">
    <div class="workshops-head">
      <h2>
        {t.workshops.headLead} <span class="it">{t.workshops.headEm}</span> {t.workshops.headTail}
      </h2>
      <div class="right">
        <span class="eyebrow">{t.workshops.eyebrow}</span>
        <p style="margin-top: 14px">{t.workshops.intro}</p>
      </div>
    </div>

    <div class="workshops-grid">
      {t.workshops.list.map((w, i) => (
        <a href={`?w=${i}#book`} class={`workshop ${w.accent}`}>
          <span class="n">No. {w.n}</span>
          <h3>{w.title} <span class="it">{w.titleIt}</span></h3>
          <p class="desc">{w.desc}</p>
          <div class="meta-row">
            <div>
              <span class="k">{t.workshops.metaLabels.date}</span>
              <span class="v">{w.date}</span>
            </div>
            <div>
              <span class="k">{t.workshops.metaLabels.time}</span>
              <span class="v">{w.time}</span>
            </div>
            <div>
              <span class="k">{t.workshops.metaLabels.where}</span>
              <span class="v">{w.place}</span>
            </div>
            <div>
              <span class="k">{t.workshops.metaLabels.price}</span>
              <span class="v">{w.price}</span>
            </div>
          </div>
          <span class="arrow-tag" aria-hidden="true">→</span>
          <span class="seats">
            <span class="dot"></span>
            {3 + i} / 8 {t.workshops.seats}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
