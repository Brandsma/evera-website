---
import type { Copy } from '../../i18n/copy';
import { asset } from '../../lib/asset';
import HeroFigure from '../HeroFigure';
import MorphBlob from '../MorphBlob';

interface Props { t: Copy }
const { t } = Astro.props;
const lines = t.hero.headLines;

// Pre-compute stagger delays for the kinetic headline
type HeadPart = string | { it: string } | { accent: string };
let counter = 0;
const allParts = lines.map(line =>
  (line as readonly HeadPart[]).map(part => {
    const delay = counter * 0.08;
    counter++;
    return { part, delay };
  })
);
---

<section class="hero" id="top">
  <MorphBlob client:load fill="var(--sand)" opacity={0.6} dur={18000} seed={0.1}
    style={{ position: 'absolute', top: '-8%', right: '-10%', width: '70vw', maxWidth: 880, aspectRatio: '1/1', pointerEvents: 'none', zIndex: 0 }} />
  <MorphBlob client:load fill="var(--sage)" opacity={0.45} dur={24000} seed={0.6}
    style={{ position: 'absolute', bottom: '-20%', left: '-15%', width: '55vw', maxWidth: 720, aspectRatio: '1/1', pointerEvents: 'none', zIndex: 0 }} />

  <div class="hero-inner">
    <span class="eyebrow">{t.hero.eyebrow}</span>
    <div class="hero-grid">
      <div>
        <h1 class="hero-headline">
          {allParts.map((line, li) => (
            <span style="display:block">
              {line.map(({ part, delay }) => {
                const isObj = typeof part !== 'string';
                const text = isObj ? (('it' in part) ? part.it : ('accent' in part ? part.accent : '')) : part;
                const isIt = isObj && 'it' in part;
                const isAccent = isObj && 'accent' in part;
                return (
                  <span
                    class={`word${isIt ? ' it' : ''}${isAccent ? ' accent' : ''}`}
                    style={`animation-delay: ${0.1 + delay}s`}
                  >{text}</span>
                );
              })}
            </span>
          ))}
        </h1>
        <p class="hero-sub">{t.hero.sub}</p>
        <div class="hero-cta-row">
          <a href="#workshops" class="btn">
            {t.hero.ctaPrimary} <span class="arrow">→</span>
          </a>
          <a href="#about" class="btn ghost">{t.hero.ctaSecondary}</a>
        </div>
      </div>
      <div class="hero-fig-card">
        <HeroFigure client:load accent="#3d6464" ink="#5e3c22" />
      </div>
    </div>
  </div>

  <div class="hero-stats">
    <div class="hero-stat">
      <div class="n">{t.hero.stat1[0]}</div>
      <div class="l">{t.hero.stat1[1]}</div>
    </div>
    <div class="hero-stat">
      <div class="n">{t.hero.stat2[0]}</div>
      <div class="l">{t.hero.stat2[1]}</div>
    </div>
    <div class="hero-stat">
      <div class="n">{t.hero.stat3[0]}</div>
      <div class="l">{t.hero.stat3[1]}</div>
    </div>
    <div class="hero-scroll">
      <span>{t.hero.scroll}</span>
      <span class="hero-scroll-line"></span>
    </div>
  </div>
</section>
