---
import type { Copy, HeadPart } from '../../i18n/copy';
import MorphBlob from '../MorphBlob';

interface Props { t: Copy }
const { t } = Astro.props;

// Pre-compute stagger delays for the kinetic headline
let counter = 0;
const allParts = t.hero.headLines.map(line =>
  line.map((part: HeadPart) => {
    const delay = counter * 0.08;
    counter++;
    return { part, delay };
  })
);
---

<section class="hero" id="top">
  <MorphBlob client:load fill="var(--sand)" opacity={0.6} dur={18000} seed={0.1}
    style={{ position: 'absolute', top: '-8%', right: '-10%', width: '70vw', maxWidth: 880, aspectRatio: '1/1', pointerEvents: 'none', zIndex: 0 }} />
  <MorphBlob client:load fill="var(--sage)" opacity={0.45} dur={24000} seed={0.6}
    style={{ position: 'absolute', bottom: '-20%', left: '-15%', width: '55vw', maxWidth: 720, aspectRatio: '1/1', pointerEvents: 'none', zIndex: 0 }} />

  <div class="hero-inner">
    <span class="eyebrow">{t.hero.eyebrow}</span>
    <h1 class="hero-headline">
      {allParts.map(line => (
        <span style="display:block">
          {line.map(({ part, delay }) => {
            const isObj = typeof part !== 'string';
            const text = isObj ? ('it' in part ? part.it : part.accent) : part;
            const isIt = isObj && 'it' in part;
            const isAccent = isObj && 'accent' in part;
            return (
              <span
                class={`word${isIt ? ' it' : ''}${isAccent ? ' accent' : ''}`}
                style={`animation-delay: ${0.1 + delay}s`}
              >{text}</span>
            );
          })}
        </span>
      ))}
    </h1>
    <p class="hero-sub">{t.hero.sub}</p>
    <div class="hero-cta-row">
      <a href="#offerings" class="btn">
        {t.hero.ctaPrimary} <span class="arrow">→</span>
      </a>
      <a href="#contact" class="btn ghost">{t.hero.ctaSecondary}</a>
    </div>
  </div>
</section>
