---
import type { Copy } from '../../i18n/copy';
interface Props { t: Copy }
const { t } = Astro.props;
---

<section class="manifesto">
  <div class="shell">
    <span class="eyebrow">{t.manifesto.eyebrow}</span>
    <div style="margin-top: 24px">
      {t.manifesto.text.map((line, i) => (
        <p class={`line${i === t.manifesto.text.length - 1 ? ' last' : ''}`}>
          <span class={i === 0 ? 'it' : ''}>{line}</span>
        </p>
      ))}
    </div>
  </div>
</section>
