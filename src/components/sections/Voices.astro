---
import type { Copy } from '../../i18n/copy';

interface Props { t: Copy }
const { t } = Astro.props;
---

<div class="voices">
  <div class="voices-head">
    <span class="eyebrow">{t.voices.eyebrow}</span>
    <h3>
      {t.voices.headLead} <span class="it">{t.voices.headEm}</span>
    </h3>
  </div>
  <div class="voices-grid">
    {t.voices.list.map(q => (
      <div class="voice">
        <div class="mark">"</div>
        <p>{q.text}</p>
        <div class="who">
          <span class="name">{q.name}</span>
          <span class="role">{q.role}</span>
        </div>
      </div>
    ))}
  </div>
</div>
