---
import type { Copy } from '../../i18n/copy';
import { asset } from '../../lib/asset';

interface Props { t: Copy }
const { t } = Astro.props;
---

<section class="section about" id="about">
  <div class="shell">
    <div class="about-grid">
      <div class="about-portrait">
        <img src={asset('images/michelle-portrait.jpg')} alt={t.about.portrait} loading="lazy" />
      </div>
      <div class="about-text">
        <span class="eyebrow">{t.about.eyebrow}</span>
        <h2>
          {t.about.headLead} <span class="it">{t.about.headEm}</span> {t.about.headMid} <span class="it">{t.about.headEm2}</span>{t.about.headTail}
        </h2>
        {t.about.paragraphs.map(p => <p>{p}</p>)}
        <div class="creds">
          {t.about.creds.map(([yr, what]) => (
            <div class="row">
              <span class="yr">{yr}</span>
              <span class="what">{what}</span>
            </div>
          ))}
        </div>
        <div class="about-pull">"{t.about.pull}"</div>
      </div>
    </div>
  </div>
</section>
