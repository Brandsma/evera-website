---
import type { Copy } from "../i18n/copy";
import { asset } from "../lib/asset";

interface Props {
  t: Copy;
  /** Where the EN / NL switch links point. Defaults to the two homepages. */
  enHref?: string;
  nlHref?: string;
}

const base = import.meta.env.BASE_URL;
const { t, enHref = base, nlHref = `${base}nl/` } = Astro.props;

// In-page anchors resolve against the homepage of the current language.
const home = t.lang === "en" ? base : `${base}nl/`;
---

<nav class="nav">
  <a href={home} class="brand">
    <img src={asset("assets/evera-mark.png")} alt="Evera" class="mark" />
    <div class="stack">
      <span class="wordmark">Evera</span>
      <span class="tag">Movement</span>
    </div>
  </a>

  <div class="nav-links">
    <a href={`${home}#about`}>{t.nav.about}</a>
    <a href={`${home}#offerings`}>{t.nav.offerings}</a>
    <a href={`${home}#portfolio`}>{t.nav.portfolio}</a>
    <a href={`${home}#contact`}>{t.nav.contact}</a>
    <span class="lang-switch">
      <a href={enHref} class={t.lang === "en" ? "on" : ""}>EN</a>
      <span style="color: var(--rule)">/</span>
      <a href={nlHref} class={t.lang === "nl" ? "on" : ""}>NL</a>
    </span>
    <a href={`${home}#contact`} class="btn">
      {t.nav.cta}
      <span class="arrow">→</span>
    </a>
  </div>
</nav>
