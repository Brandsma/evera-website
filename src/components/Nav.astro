---
import type { Copy } from '../i18n/copy';
import { asset } from '../lib/asset';

interface Props {
  t: Copy;
}

const { t } = Astro.props;
const otherLangHref = t.lang === 'en' ? `${import.meta.env.BASE_URL}nl/` : import.meta.env.BASE_URL;
---

<nav class="nav">
  <a href={import.meta.env.BASE_URL} class="brand">
    <img src={asset('assets/evera-mark.png')} alt="Evera" class="mark" />
    <div class="stack">
      <span class="wordmark">Evera</span>
      <span class="tag">Movement space</span>
    </div>
  </a>

  <div class="nav-links">
    <a href="#workshops">{t.nav.workshops}</a>
    <a href="#about">{t.nav.about}</a>
    <a href="#voices">{t.nav.voices}</a>
    <a href="#visit">{t.nav.visit}</a>
    <span class="lang-switch">
      <a href={import.meta.env.BASE_URL} class={t.lang === 'en' ? 'on' : ''}>EN</a>
      <span style="color: var(--rule)">/</span>
      <a href={`${import.meta.env.BASE_URL}nl/`} class={t.lang === 'nl' ? 'on' : ''}>NL</a>
    </span>
    <a href="#book" class="btn">
      {t.nav.book} <span class="arrow">→</span>
    </a>
  </div>

  <!-- Mobile: only show lang switch since nav-links is hidden -->
  <div class="mobile-lang">
    <a href={import.meta.env.BASE_URL} class={t.lang === 'en' ? 'on' : ''}>EN</a>
    <span style="color: var(--rule)">/</span>
    <a href={`${import.meta.env.BASE_URL}nl/`} class={t.lang === 'nl' ? 'on' : ''}>NL</a>
    <a href="#book" class="btn" style="margin-left: 12px; padding: 10px 18px; font-size: 13px;">
      {t.nav.book}
    </a>
  </div>
</nav>
