---
import type { Copy } from '../i18n/copy';
import type { Post } from '../lib/substack';

interface Props {
  t: Copy;
  posts: Post[];
}

const { t, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="posts-list">
  {posts.map(p => (
    <a class="post-row" href={`${base}blog/${p.slug}/`}>
      <span class="post-meta">
        <span class="post-date">{p.dates[t.lang]}</span>
        <span class="post-read">{p.readingTime} {t.readingLabel}</span>
      </span>
      <span class="post-title">{p.title}</span>
      <span class="post-go" aria-hidden="true">→</span>
    </a>
  ))}
</div>
